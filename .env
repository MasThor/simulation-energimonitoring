# ============================================================
# Manufacturing Energy Monitoring — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values before running.
# NEVER commit .env with real credentials to version control.

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=R3d!sP@ss2024

# --- EMQX ---
EMQX_MQTT_PORT=1883
EMQX_DASHBOARD_PORT=18083
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=Emqx@Admin2024

# MQTT credentials used by aggregator & Node-RED
MQTT_USER=iot_user
MQTT_PASS=M!tt@IoT2024

# --- InfluxDB v3 ---
INFLUX_HOST=http://influxdb:8086
INFLUX_TOKEN=apiv3_ds_pESsacfI0_vXWdSHp49SZaXPbODKnd8gaSQopgUOV-ijAiLEeqLy3IiyXhp0bQtGmN1pHOHS83CJfKWqP7w
INFLUX_DATABASE=energy_monitoring

# Retention (days) — enforced at application level
RETENTION_RAW_DAYS=14
RETENTION_MINUTE_DAYS=30

# --- Node-RED ---
NODE_RED_PORT=1880

# --- Aggregator tuning ---
# How many seconds to offset the minute-job query window
# (avoids edge-case where clock skew causes missed last point)
AGG_MINUTE_OFFSET_SEC=5
AGG_HOUR_OFFSET_SEC=30
