    {
        "id": "sim-cmt-1",
        "type": "comment",
        "z": "tab-simulator",
        "name": "[1] Trigger setiap 10s — auto start saat deploy",
        "info": "",
        "x": 420,
        "y": 60,
        "wires": []
    },
    {
        "id": "sim-fn-gen",
        "type": "function",
        "z": "tab-simulator",
        "name": "[2] Generate 5 Machine Telemetry",
        "func": "// [2] Generate realistic 5-machine telemetry\nconst machines = [{\"id\": \"machine_01\", \"location\": \"produksi_a\", \"basePower\": 12, \"baseVoltage\": 220, \"baseCurrent\": 55}, {\"id\": \"machine_02\", \"location\": \"produksi_a\", \"basePower\": 10, \"baseVoltage\": 218, \"baseCurrent\": 46}, {\"id\": \"machine_03\", \"location\": \"produksi_b\", \"basePower\": 22, \"baseVoltage\": 221, \"baseCurrent\": 100}, {\"id\": \"machine_04\", \"location\": \"gudang\", \"basePower\": 4, \"baseVoltage\": 219, \"baseCurrent\": 18}, {\"id\": \"machine_05\", \"location\": \"office\", \"basePower\": 3, \"baseVoltage\": 220, \"baseCurrent\": 14}];\nconst vary  = (base, pct) => base * (1 + (Math.random() - 0.5) * 2 * pct);\nconst round = (v, d)      => Math.round(v * Math.pow(10, d)) / Math.pow(10, d);\nconst INTERVAL_SEC = 10;\nconst now = new Date().toISOString();\nmsg.payload = machines.map(m => {\n  const power   = round(vary(m.basePower,   0.2),  3);\n  const voltage = round(vary(m.baseVoltage, 0.02), 1);\n  const current = round(vary(m.baseCurrent, 0.15), 2);\n  const pf      = round(0.85 + Math.random() * 0.12, 3);\n  const energy  = round(power * INTERVAL_SEC / 3600, 6);\n  return { machine_id: m.id, location: m.location, timestamp: now,\n    power_kw: power, voltage_v: voltage, current_a: current,\n    energy_kwh: energy, power_factor: pf };\n});\nnode.status({ fill: 'green', shape: 'dot', text: 'x5 @ ' + now.substring(11,19) });\nreturn msg;",
        "outputs": 1,
        "x": 420,
        "y": 180,
        "wires": [
            [
                "sim-split"
            ]
        ]
    },
    {
        "id": "sim-cmt-2",
        "type": "comment",
        "z": "tab-simulator",
