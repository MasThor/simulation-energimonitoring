[
    {
        "id": "tab-migration",
        "type": "tab",
        "label": "Migration / Seeders",
        "disabled": false,
        "info": "Tab 1: Create DBs + Tables + Seed historical data. Runs once on startup."
    },
    {
        "id": "tab-simulator",
        "type": "tab",
        "label": "Simulator",
        "disabled": false,
        "info": "Tab 2: Generate 5-machine telemetry every 10s, publish to EMQX MQTT."
    },
    {
        "id": "tab-ingestion",
        "type": "tab",
        "label": "Ingestion",
        "disabled": false,
        "info": "Tab 3: Subscribe MQTT energy/+/data -> validate -> write RAW to InfluxDB."
    },
    {
        "id": "tab-dashboard",
        "type": "tab",
        "label": "Dashboard Output",
        "disabled": false,
        "info": "Tab 4: Query 3 DBs -> JSON API at GET /api/dashboard/energy"
    },
    {
        "id": "cfg-emqx",
        "type": "mqtt-broker",
        "name": "EMQX Broker",
        "broker": "emqx",
        "port": "1883",
        "clientid": "nodered-energy",
        "autoConnect": true,
        "usetls": false,
        "protocolVersion": "5",
        "keepalive": "60",
        "cleansession": true,
        "autoUnsubscribe": true,
        "birthTopic": "",
        "birthQos": "0",
        "birthPayload": "",
        "closeTopic": "",
        "closeQos": "0",
        "closePayload": "",
        "willTopic": "",
        "willQos": "0",
        "willPayload": ""
    },
    {
        "id": "mig-trigger",
        "type": "inject",
        "z": "tab-migration",
        "name": "Startup / Manual Trigger",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "",
        "crontab": "",
        "once": true,
        "onceDelay": 1.5,
        "topic": "",
        "payload": "start",
        "payloadType": "str",
        "x": 160,
        "y": 80,
        "wires": [
            [
                "mig-fn-init"
            ]
        ]
    },
    {
        "id": "mig-cmt-1",
        "type": "comment",
        "z": "tab-migration",
        "name": "[1] POST /api/v3/configure/database — Create 3 databases",
        "info": "",
        "x": 500,
        "y": 80,
        "wires": []
    },
    {
        "id": "mig-fn-init",
        "type": "function",
        "z": "tab-migration",
        "name": "[1] Init Migration",
        "func": "// [1] Init: define databases and tables, use InfluxDB v3 native API\nconst HOST  = 'http://influxdb:8181';\nconst TOKEN = 'apiv3_ds_pESsacfI0_vXWdSHp49SZaXPbODKnd8gaSQopgUOV-ijAiLEeqLy3IiyXhp0bQtGmN1pHOHS83CJfKWqP7w';\nconst databases = [\n  { db: 'energy_monitoring', retention_period: null,  label: 'RAW (permanent)' },\n  { db: 'energy_minutes',    retention_period: '14d', label: 'MINUTES (14d)' },\n  { db: 'energy_hour',       retention_period: null,  label: 'HOURLY (permanent)' }\n];\nconst tables = [\n  { db: 'energy_monitoring', table: 'energy_raw',    tags: ['machine_id','location'] },\n  { db: 'energy_minutes',    table: 'energy_minute', tags: ['machine_id','location'] },\n  { db: 'energy_hour',       table: 'energy_hour',   tags: ['machine_id','location'] }\n];\nflow.set('mig_host', HOST);\nflow.set('mig_token', TOKEN);\nflow.set('mig_databases', databases);\nflow.set('mig_tables', tables);\nflow.set('mig_db_idx', 0);\nflow.set('mig_tbl_idx', 0);\nnode.status({ fill: 'blue', shape: 'dot', text: 'Starting...' });\nmsg.payload = 'start';\nreturn msg;",
        "outputs": 1,
        "x": 500,
        "y": 120,
        "wires": [
            [
                "mig-fn-next-db"
            ]
        ]
    },
    {
        "id": "mig-fn-next-db",
        "type": "function",
        "z": "tab-migration",
        "name": "[1] Next DB",
        "func": "// [1] Loop: POST /api/v3/configure/database\nconst databases = flow.get('mig_databases') || [];\nconst idx = flow.get('mig_db_idx') || 0;\nif (idx >= databases.length) {\n  node.status({ fill: 'green', shape: 'dot', text: idx + ' DBs created' });\n  return [null, msg];\n}\nconst db = databases[idx];\nconst body = { db: db.db };\nif (db.retention_period) body.retention_period = db.retention_period;\nmsg.url     = flow.get('mig_host') + '/api/v3/configure/database';\nmsg.method  = 'POST';\nmsg.headers = { 'Authorization': 'Bearer ' + flow.get('mig_token'), 'Content-Type': 'application/json' };\nmsg.payload = JSON.stringify(body);\nmsg._label  = db.label;\nmsg._idx    = idx;\nnode.status({ fill: 'blue', shape: 'ring', text: 'DB: ' + db.db });\nreturn [msg, null];",
        "outputs": 2,
        "x": 740,
        "y": 120,
        "wires": [
            [
                "mig-http-db"
            ],
            [
                "mig-fn-next-tbl"
            ]
        ]
    },
    {
        "id": "mig-http-db",
        "type": "http request",
        "z": "tab-migration",
        "name": "[1] POST /api/v3/configure/database",
        "method": "use",
        "ret": "txt",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "x": 1000,
        "y": 120,
        "wires": [
            [
                "mig-fn-db-result"
            ]
        ]
    },
    {
        "id": "mig-fn-db-result",
        "type": "function",
        "z": "tab-migration",
        "name": "[1] Advance DB Index",
        "func": "const code = msg.statusCode;\nif (code === 200 || code === 201) {\n  node.log('[mig] DB created: ' + msg._label);\n} else if (code === 409 || code === 422) {\n  node.log('[mig] DB exists: ' + msg._label + ' (OK)');\n} else {\n  node.warn('[mig] DB status ' + code + ': ' + msg.payload);\n}\nflow.set('mig_db_idx', (msg._idx || 0) + 1);\nreturn msg;",
        "outputs": 1,
        "x": 1000,
        "y": 180,
        "wires": [
            [
                "mig-fn-next-db"
            ]
        ]
    },
    {
        "id": "mig-cmt-2",
        "type": "comment",
        "z": "tab-migration",
        "name": "[2] POST /api/v3/configure/table — Create 3 tables with tags",
        "info": "",
        "x": 740,
        "y": 240,
        "wires": []
    },
    {
        "id": "mig-fn-next-tbl",
        "type": "function",
        "z": "tab-migration",
        "name": "[2] Next Table",
        "func": "// [2] Loop: POST /api/v3/configure/table\nconst tables = flow.get('mig_tables') || [];\nconst idx = flow.get('mig_tbl_idx') || 0;\nif (idx >= tables.length) {\n  node.status({ fill: 'green', shape: 'dot', text: idx + ' tables created' });\n  return [null, msg];\n}\nconst t = tables[idx];\nmsg.url     = flow.get('mig_host') + '/api/v3/configure/table';\nmsg.method  = 'POST';\nmsg.headers = { 'Authorization': 'Bearer ' + flow.get('mig_token'), 'Content-Type': 'application/json' };\nmsg.payload = JSON.stringify({ db: t.db, table: t.table, tags: t.tags });\nmsg._tbl    = t.db + '.' + t.table;\nmsg._tidx   = idx;\nnode.status({ fill: 'blue', shape: 'ring', text: 'Table: ' + t.table });\nreturn [msg, null];",
        "outputs": 2,
        "x": 740,
        "y": 280,
        "wires": [
            [
                "mig-http-tbl"
            ],
            [
                "mig-fn-seed-raw"
            ]
        ]
    },
    {
        "id": "mig-http-tbl",
        "type": "http request",
        "z": "tab-migration",
        "name": "[2] POST /api/v3/configure/table",
        "method": "use",
        "ret": "txt",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "x": 1000,
        "y": 280,
        "wires": [
            [
                "mig-fn-tbl-result"
            ]
        ]
    },
    {
        "id": "mig-fn-tbl-result",
        "type": "function",
        "z": "tab-migration",
        "name": "[2] Advance Table Index",
        "func": "const code = msg.statusCode;\nif (code === 200 || code === 201) {\n  node.log('[mig] Table created: ' + msg._tbl);\n} else if (code === 409 || code === 422) {\n  node.log('[mig] Table exists: ' + msg._tbl + ' (OK)');\n} else {\n  node.warn('[mig] Table status ' + code + ' for ' + msg._tbl + ': ' + msg.payload);\n}\nflow.set('mig_tbl_idx', (msg._tidx || 0) + 1);\nreturn msg;",
        "outputs": 1,
        "x": 1000,
        "y": 340,
        "wires": [
            [
                "mig-fn-next-tbl"
            ]
        ]
    },
    {
        "id": "mig-cmt-3",
        "type": "comment",
        "z": "tab-migration",
        "name": "[3] POST /api/v3/write_lp?db=energy_monitoring — Seed RAW 24h",
        "info": "",
        "x": 500,
        "y": 420,
        "wires": []
    },
    {
        "id": "mig-fn-seed-raw",
        "type": "function",
        "z": "tab-migration",
        "name": "[3] Generate RAW Seed (24h × 5 mesin × 10s)",
        "func": "// [3] Seed RAW: POST /api/v3/write_lp?db=energy_monitoring\nconst HOST  = flow.get('mig_host');\nconst TOKEN = flow.get('mig_token');\nconst machines = [{\"id\": \"machine_01\", \"location\": \"produksi_a\", \"basePower\": 12, \"baseVoltage\": 220, \"baseCurrent\": 55}, {\"id\": \"machine_02\", \"location\": \"produksi_a\", \"basePower\": 10, \"baseVoltage\": 218, \"baseCurrent\": 46}, {\"id\": \"machine_03\", \"location\": \"produksi_b\", \"basePower\": 22, \"baseVoltage\": 221, \"baseCurrent\": 100}, {\"id\": \"machine_04\", \"location\": \"gudang\", \"basePower\": 4, \"baseVoltage\": 219, \"baseCurrent\": 18}, {\"id\": \"machine_05\", \"location\": \"office\", \"basePower\": 3, \"baseVoltage\": 220, \"baseCurrent\": 14}];\nconst INTERVAL_SEC = 10, LOOKBACK_HOURS = 24, BATCH_SIZE = 500;\nconst now = Date.now(), startMs = now - (LOOKBACK_HOURS * 3600 * 1000);\nconst vary  = (base, pct) => base * (1 + (Math.random() - 0.5) * 2 * pct);\nconst round = (v, d)      => Math.round(v * Math.pow(10, d)) / Math.pow(10, d);\nlet lines = [], batches = [];\nconst flush = () => {\n  if (!lines.length) return;\n  batches.push({ url: HOST + '/api/v3/write_lp?db=energy_monitoring', body: lines.join('\\n') });\n  lines = [];\n};\nfor (let ts = startMs; ts < now; ts += INTERVAL_SEC * 1000) {\n  const tsNs = (ts * 1000000).toString();\n  for (const m of machines) {\n    const power   = round(vary(m.basePower,   0.20), 3);\n    const voltage = round(vary(m.baseVoltage, 0.02), 1);\n    const current = round(vary(m.baseCurrent, 0.15), 2);\n    const pf      = round(0.85 + Math.random() * 0.12, 3);\n    const energy  = round(power * INTERVAL_SEC / 3600, 6);\n    lines.push('energy_raw,machine_id=' + m.id + ',location=' + m.location +\n      ' power_kw=' + power + ',voltage_v=' + voltage + ',current_a=' + current +\n      ',energy_kwh=' + energy + ',power_factor=' + pf + ' ' + tsNs);\n    if (lines.length >= BATCH_SIZE) flush();\n  }\n}\nflush();\nflow.set('seed_raw_batches', batches);\nflow.set('seed_raw_idx', 0);\nnode.status({ fill: 'blue', shape: 'dot', text: 'RAW: ' + batches.length + ' batches' });\nmsg.payload = { totalBatches: batches.length };\nreturn msg;",
        "outputs": 1,
        "x": 500,
        "y": 460,
        "wires": [
            [
                "mig-fn-next-raw"
            ]
        ]
    },
    {
        "id": "mig-fn-next-raw",
        "type": "function",
        "z": "tab-migration",
        "name": "[3] Next RAW Batch",
        "func": "const batches = flow.get('seed_raw_batches') || [];\nconst idx = flow.get('seed_raw_idx') || 0;\nif (idx >= batches.length) {\n  node.status({ fill: 'green', shape: 'dot', text: 'RAW done: ' + batches.length });\n  return [null, msg];\n}\nconst b = batches[idx];\nflow.set('seed_raw_idx', idx + 1);\nmsg.url     = b.url;\nmsg.method  = 'POST';\nmsg.headers = { 'Authorization': 'Bearer ' + flow.get('mig_token'), 'Content-Type': 'text/plain' };\nmsg.payload = b.body;\nnode.status({ fill: 'blue', shape: 'ring', text: 'RAW batch ' + (idx+1) + '/' + batches.length });\nreturn [msg, null];",
        "outputs": 2,
        "x": 740,
        "y": 460,
        "wires": [
            [
                "mig-http-raw"
            ],
            [
                "mig-fn-seed-min"
            ]
        ]
    },
    {
        "id": "mig-http-raw",
        "type": "http request",
        "z": "tab-migration",
        "name": "[3] POST /api/v3/write_lp RAW",
        "method": "use",
        "ret": "txt",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "x": 1000,
        "y": 460,
        "wires": [
            [
                "mig-fn-after-raw"
            ]
        ]
    },
    {
        "id": "mig-fn-after-raw",
        "type": "function",
        "z": "tab-migration",
        "name": "[3] Advance RAW Index",
        "func": "if(msg.statusCode!==200&&msg.statusCode!==204){node.warn('[seed-raw] '+msg.statusCode+': '+msg.payload);} return msg;",
        "outputs": 1,
        "x": 1000,
        "y": 520,
        "wires": [
            [
                "mig-fn-next-raw"
            ]
        ]
    },
    {
        "id": "mig-cmt-4",
        "type": "comment",
        "z": "tab-migration",
        "name": "[4] POST /api/v3/write_lp?db=energy_minutes — Seed MINUTES 24h",
        "info": "",
        "x": 500,
        "y": 600,
        "wires": []
    },
    {
        "id": "mig-fn-seed-min",
        "type": "function",
        "z": "tab-migration",
        "name": "[4] Generate MINUTES Seed (24h × 5 mesin × 1m)",
        "func": "// [4] Seed MINUTES: POST /api/v3/write_lp?db=energy_minutes\nconst HOST  = flow.get('mig_host');\nconst TOKEN = flow.get('mig_token');\nconst machines = [{\"id\": \"machine_01\", \"location\": \"produksi_a\", \"basePower\": 12, \"baseVoltage\": 220, \"baseCurrent\": 55}, {\"id\": \"machine_02\", \"location\": \"produksi_a\", \"basePower\": 10, \"baseVoltage\": 218, \"baseCurrent\": 46}, {\"id\": \"machine_03\", \"location\": \"produksi_b\", \"basePower\": 22, \"baseVoltage\": 221, \"baseCurrent\": 100}, {\"id\": \"machine_04\", \"location\": \"gudang\", \"basePower\": 4, \"baseVoltage\": 219, \"baseCurrent\": 18}, {\"id\": \"machine_05\", \"location\": \"office\", \"basePower\": 3, \"baseVoltage\": 220, \"baseCurrent\": 14}];\nconst LOOKBACK_HOURS = 24, BATCH_SIZE = 500;\nconst now = Date.now(), startMs = now - (LOOKBACK_HOURS * 3600 * 1000);\nconst vary  = (base, pct) => base * (1 + (Math.random() - 0.5) * 2 * pct);\nconst round = (v, d)      => Math.round(v * Math.pow(10, d)) / Math.pow(10, d);\nlet lines = [], batches = [];\nconst flush = () => {\n  if (!lines.length) return;\n  batches.push({ url: HOST + '/api/v3/write_lp?db=energy_minutes', body: lines.join('\\n') });\n  lines = [];\n};\nfor (let ts = startMs; ts < now; ts += 60 * 1000) {\n  const tsNs = (Math.floor(ts / 60000) * 60000 * 1000000).toString();\n  for (const m of machines) {\n    const avgPow = round(vary(m.basePower,   0.15), 3);\n    const sumE   = round(avgPow * 60 / 3600, 6);\n    const avgV   = round(vary(m.baseVoltage, 0.02), 1);\n    const avgA   = round(avgPow * 1000 / avgV, 2);\n    const avgPF  = round(0.87 + Math.random() * 0.10, 3);\n    const minPow = round(avgPow * 0.85, 3);\n    const maxPow = round(avgPow * 1.18, 3);\n    lines.push('energy_minute,machine_id=' + m.id + ',location=' + m.location +\n      ' avg_power_kw=' + avgPow + ',sum_energy_kwh=' + sumE +\n      ',avg_voltage_v=' + avgV + ',avg_current_a=' + avgA +\n      ',avg_power_factor=' + avgPF + ',min_power_kw=' + minPow +\n      ',max_power_kw=' + maxPow + ',sample_count=6i' + ' ' + tsNs);\n    if (lines.length >= BATCH_SIZE) flush();\n  }\n}\nflush();\nflow.set('seed_min_batches', batches);\nflow.set('seed_min_idx', 0);\nnode.status({ fill: 'blue', shape: 'dot', text: 'MINUTES: ' + batches.length + ' batches' });\nmsg.payload = { totalBatches: batches.length };\nreturn msg;",
        "outputs": 1,
        "x": 500,
        "y": 640,
        "wires": [
            [
                "mig-fn-next-min"
            ]
        ]
    },
    {
        "id": "mig-fn-next-min",
        "type": "function",
        "z": "tab-migration",
        "name": "[4] Next MINUTES Batch",
        "func": "const batches = flow.get('seed_min_batches') || [];\nconst idx = flow.get('seed_min_idx') || 0;\nif (idx >= batches.length) {\n  node.status({ fill: 'green', shape: 'dot', text: 'MINUTES done: ' + batches.length });\n  return [null, msg];\n}\nconst b = batches[idx];\nflow.set('seed_min_idx', idx + 1);\nmsg.url     = b.url;\nmsg.method  = 'POST';\nmsg.headers = { 'Authorization': 'Bearer ' + flow.get('mig_token'), 'Content-Type': 'text/plain' };\nmsg.payload = b.body;\nnode.status({ fill: 'blue', shape: 'ring', text: 'MIN batch ' + (idx+1) + '/' + batches.length });\nreturn [msg, null];",
        "outputs": 2,
        "x": 740,
        "y": 640,
        "wires": [
            [
                "mig-http-min"
            ],
            [
                "mig-fn-seed-hourly"
            ]
        ]
    },
    {
        "id": "mig-http-min",
        "type": "http request",
        "z": "tab-migration",
        "name": "[4] POST /api/v3/write_lp MINUTES",
        "method": "use",
        "ret": "txt",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "x": 1000,
        "y": 640,
        "wires": [
            [
                "mig-fn-after-min"
            ]
        ]
    },
    {
        "id": "mig-fn-after-min",
        "type": "function",
        "z": "tab-migration",
        "name": "[4] Advance MINUTES Index",
        "func": "if(msg.statusCode!==200&&msg.statusCode!==204){node.warn('[seed-min] '+msg.statusCode+': '+msg.payload);} return msg;",
        "outputs": 1,
        "x": 1000,
        "y": 700,
        "wires": [
            [
                "mig-fn-next-min"
            ]
        ]
    },
    {
        "id": "mig-cmt-5",
        "type": "comment",
        "z": "tab-migration",
        "name": "[5] POST /api/v3/write_lp?db=energy_hour — Seed HOURLY 24h",
        "info": "",
        "x": 500,
        "y": 780,
        "wires": []
    },
    {
        "id": "mig-fn-seed-hourly",
        "type": "function",
        "z": "tab-migration",
        "name": "[5] Generate HOURLY Seed (24h × 5 mesin)",
        "func": "// [5] Seed HOURLY: POST /api/v3/write_lp?db=energy_hour\nconst HOST  = flow.get('mig_host');\nconst TOKEN = flow.get('mig_token');\nconst machines = [{\"id\": \"machine_01\", \"location\": \"produksi_a\", \"basePower\": 12, \"baseVoltage\": 220, \"baseCurrent\": 55}, {\"id\": \"machine_02\", \"location\": \"produksi_a\", \"basePower\": 10, \"baseVoltage\": 218, \"baseCurrent\": 46}, {\"id\": \"machine_03\", \"location\": \"produksi_b\", \"basePower\": 22, \"baseVoltage\": 221, \"baseCurrent\": 100}, {\"id\": \"machine_04\", \"location\": \"gudang\", \"basePower\": 4, \"baseVoltage\": 219, \"baseCurrent\": 18}, {\"id\": \"machine_05\", \"location\": \"office\", \"basePower\": 3, \"baseVoltage\": 220, \"baseCurrent\": 14}];\nconst LOOKBACK_HOURS = 24;\nconst now = Date.now(), startMs = now - (LOOKBACK_HOURS * 3600 * 1000);\nconst vary  = (base, pct) => base * (1 + (Math.random() - 0.5) * 2 * pct);\nconst round = (v, d)      => Math.round(v * Math.pow(10, d)) / Math.pow(10, d);\nlet lines = [];\nfor (let ts = startMs; ts < now; ts += 3600 * 1000) {\n  const tsNs = (Math.floor(ts / 3600000) * 3600000 * 1000000).toString();\n  for (const m of machines) {\n    const avgPow = round(vary(m.basePower,   0.12), 3);\n    const sumE   = round(avgPow * 1, 4);\n    const avgV   = round(vary(m.baseVoltage, 0.02), 1);\n    const avgA   = round(avgPow * 1000 / avgV, 2);\n    const avgPF  = round(0.88 + Math.random() * 0.09, 3);\n    const minPow = round(avgPow * 0.80, 3);\n    const maxPow = round(avgPow * 1.20, 3);\n    lines.push('energy_hour,machine_id=' + m.id + ',location=' + m.location +\n      ' avg_power_kw=' + avgPow + ',sum_energy_kwh=' + sumE +\n      ',avg_voltage_v=' + avgV + ',avg_current_a=' + avgA +\n      ',avg_power_factor=' + avgPF + ',min_power_kw=' + minPow +\n      ',max_power_kw=' + maxPow + ',sample_count=360i' + ' ' + tsNs);\n  }\n}\nmsg.url     = HOST + '/api/v3/write_lp?db=energy_hour';\nmsg.method  = 'POST';\nmsg.headers = { 'Authorization': 'Bearer ' + TOKEN, 'Content-Type': 'text/plain' };\nmsg.payload = lines.join('\\n');\nnode.status({ fill: 'blue', shape: 'dot', text: 'Writing ' + lines.length + ' HOURLY...' });\nreturn msg;",
        "outputs": 1,
        "x": 500,
        "y": 820,
        "wires": [
            [
                "mig-http-hourly"
            ]
        ]
    },
    {
        "id": "mig-http-hourly",
        "type": "http request",
        "z": "tab-migration",
        "name": "[5] POST /api/v3/write_lp HOURLY",
        "method": "use",
        "ret": "txt",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "x": 760,
        "y": 820,
        "wires": [
            [
                "mig-fn-done"
            ]
        ]
    },
    {
        "id": "mig-fn-done",
        "type": "function",
        "z": "tab-migration",
        "name": "[5] Migration Complete",
        "func": "const ok = msg.statusCode === 200 || msg.statusCode === 204;\nnode.status({ fill: 'green', shape: 'dot', text: ok ? 'All seeding done!' : 'Done (status ' + msg.statusCode + ')' });\nmsg.payload = { status: 'done', influx_code: msg.statusCode };\nreturn msg;",
        "outputs": 1,
        "x": 1000,
        "y": 820,
        "wires": [
            [
                "mig-debug"
            ]
        ]
    },
    {
        "id": "mig-debug",
        "type": "debug",
        "z": "tab-migration",
        "name": "Seeder Status",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
