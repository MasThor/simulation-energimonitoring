    {
        "id": "ing-cmt-2",
        "type": "comment",
        "z": "tab-ingestion",
        "name": "[2] Parse JSON string -> object",
        "info": "",
        "x": 660,
        "y": 60,
        "wires": []
    },
    {
        "id": "ing-fn-validate",
        "type": "function",
        "z": "tab-ingestion",
        "name": "[3] Validate & Sanitize",
        "func": "// [3] Validate: drop if missing/NaN field\nconst d = msg.payload;\nconst required = ['machine_id','location','power_kw','voltage_v','current_a','energy_kwh','power_factor'];\nfor (const f of required) {\n  if (d[f] === undefined || d[f] === null) {\n    node.warn('[ing] Dropped: missing ' + f);\n    node.status({ fill: 'red', shape: 'ring', text: 'Missing: ' + f });\n    return null;\n  }\n}\nfor (const f of ['power_kw','voltage_v','current_a','energy_kwh','power_factor']) {\n  const v = parseFloat(d[f]);\n  if (isNaN(v)) {\n    node.warn('[ing] Dropped: NaN in ' + f);\n    node.status({ fill: 'red', shape: 'ring', text: 'NaN: ' + f });\n    return null;\n  }\n  d[f] = v;\n}\nmsg.payload = d;\nreturn msg;",
        "outputs": 1,
        "x": 660,
        "y": 100,
        "wires": [
            [
                "ing-fn-lp"
            ]
        ]
    },
    {
        "id": "ing-cmt-3",
        "type": "comment",
        "z": "tab-ingestion",
        "name": "[3] Validate: semua field wajib + numerik",
        "info": "",
        "x": 880,
        "y": 60,
        "wires": []
    },
    {
        "id": "ing-fn-lp",
        "type": "function",
        "z": "tab-ingestion",
        "name": "[4] Build Line Protocol",
        "func": "// [4] Build InfluxDB Line Protocol -> write to energy_monitoring\nconst d = msg.payload;\nconst esc = v => String(v).replace(/ /g,'\\\\ ').replace(/,/g,'\\\\,').replace(/=/g,'\\\\=');\nlet tsMs;\ntry { tsMs = d.timestamp ? new Date(d.timestamp).getTime() : Date.now(); if (isNaN(tsMs)) tsMs = Date.now(); }\ncatch(e) { tsMs = Date.now(); }\nconst tsNs = (tsMs * 1000000).toString();\nconst line = 'energy_raw,machine_id=' + esc(d.machine_id) + ',location=' + esc(d.location) +\n  ' power_kw=' + d.power_kw + ',voltage_v=' + d.voltage_v + ',current_a=' + d.current_a +\n  ',energy_kwh=' + d.energy_kwh + ',power_factor=' + d.power_factor + ' ' + tsNs;\nmsg.url     = 'http://influxdb:8181/api/v3/write_lp?db=energy_monitoring';\nmsg.method  = 'POST';\nmsg.headers = { 'Authorization': 'Bearer apiv3_ds_pESsacfI0_vXWdSHp49SZaXPbODKnd8gaSQopgUOV-ijAiLEeqLy3IiyXhp0bQtGmN1pHOHS83CJfKWqP7w', 'Content-Type': 'text/plain' };\nmsg.payload = line;\nreturn msg;",
        "outputs": 1,
        "x": 880,
        "y": 100,
        "wires": [
            [
                "ing-http"
            ]
        ]
    },
    {
        "id": "ing-cmt-4",
        "type": "comment",
        "z": "tab-ingestion",
        "name": "[4-5] POST /api/v3/write_lp?db=energy_monitoring",
        "info": "",
        "x": 1100,
        "y": 60,
        "wires": []
    },
    {
        "id": "ing-http",
        "type": "http request",
        "z": "tab-ingestion",
        "name": "[5] POST /api/v3/write_lp",
        "method": "use",
        "ret": "txt",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "x": 1100,
        "y": 100,
        "wires": [
            [
                "ing-fn-check"
            ]
        ]
    },
    {
        "id": "ing-fn-check",
        "type": "function",
        "z": "tab-ingestion",
        "name": "[5] Check Status",
        "func": "if (msg.statusCode === 200 || msg.statusCode === 204) {\n  node.status({ fill: 'green', shape: 'dot', text: 'OK @ ' + new Date().toISOString().substring(11,19) });\n} else {\n  node.status({ fill: 'red', shape: 'ring', text: 'Error ' + msg.statusCode });\n  node.warn('[ing] Write failed (' + msg.statusCode + '): ' + msg.payload);\n}\nreturn msg;",
        "outputs": 1,
        "x": 1100,
        "y": 160,
        "wires": [
            []
        ]
    },
