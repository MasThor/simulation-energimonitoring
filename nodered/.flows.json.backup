    },
    {
        "id": "dash-http-in",
        "type": "http in",
        "z": "tab-dashboard",
        "name": "[1] GET /api/dashboard/energy",
        "url": "/api/dashboard/energy",
        "method": "get",
        "upload": false,
        "swaggerDoc": "",
        "x": 200,
        "y": 100,
        "wires": [
            [
                "dash-fn-rt"
            ]
        ]
    },
    {
        "id": "dash-cmt-1",
        "type": "comment",
        "z": "tab-dashboard",
        "name": "[1] GET /api/dashboard/energy | Test: curl http://localhost:1880/api/dashboard/energy",
        "info": "",
        "x": 460,
        "y": 60,
        "wires": []
    },
    {
        "id": "dash-fn-rt",
        "type": "function",
        "z": "tab-dashboard",
        "name": "[2] Query Realtime (RAW DB)",
        "func": "// [2] Query realtime: last 60s, all machines\nconst TOKEN = 'apiv3_ds_pESsacfI0_vXWdSHp49SZaXPbODKnd8gaSQopgUOV-ijAiLEeqLy3IiyXhp0bQtGmN1pHOHS83CJfKWqP7w', HOST = 'http://influxdb:8181';\nflow.set('dash_req', msg.req);\nflow.set('dash_res', msg.res);\nflow.set('dash_results', {});\nconst sql = `SELECT machine_id, location,\n  LAST(power_kw) AS power_kw, LAST(voltage_v) AS voltage_v,\n  LAST(current_a) AS current_a, LAST(power_factor) AS power_factor, MAX(time) AS last_seen\nFROM energy_raw\nWHERE time >= NOW() - INTERVAL '60 seconds'\nGROUP BY machine_id, location ORDER BY machine_id ASC`;\nmsg.url     = HOST + '/api/v3/query';\nmsg.method  = 'POST';\nmsg.headers = { 'Authorization': 'Bearer ' + TOKEN, 'Content-Type': 'application/json' };\nmsg.payload = JSON.stringify({ query: sql, database: 'energy_monitoring', format: 'json' });\nreturn msg;",
        "outputs": 1,
        "x": 460,
        "y": 100,
        "wires": [
            [
                "dash-http-rt"
            ]
        ]
    },
    {
        "id": "dash-http-rt",
        "type": "http request",
        "z": "tab-dashboard",
        "name": "[2] POST /api/v3/query RAW",
        "method": "use",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "x": 720,
        "y": 100,
        "wires": [
            [
                "dash-fn-parse-rt"
            ]
        ]
    },
    {
        "id": "dash-fn-parse-rt",
        "type": "function",
        "z": "tab-dashboard",
        "name": "[2] Format Realtime",
        "func": "try {\n  const rows = Array.isArray(msg.payload) ? msg.payload : [];\n  const machines = rows.map(r => ({\n    machine_id: r.machine_id, location: r.location,\n    power_kw: parseFloat(r.power_kw)||0, voltage_v: parseFloat(r.voltage_v)||0,\n    current_a: parseFloat(r.current_a)||0, power_factor: parseFloat(r.power_factor)||0,\n    last_seen: r.last_seen\n  }));\n  const results = flow.get('dash_results') || {};\n  results.realtime = {\n    total_power_kw: Math.round(machines.reduce((s,m)=>s+m.power_kw,0)*100)/100,\n    machines\n  };\n  flow.set('dash_results', results);\n} catch(e) { node.warn('[dash] realtime: ' + e.message); }\nreturn msg;",
        "outputs": 1,
        "x": 960,
        "y": 100,
        "wires": [
            [
                "dash-fn-hourly"
            ]
        ]
    },
    {
        "id": "dash-fn-hourly",
        "type": "function",
        "z": "tab-dashboard",
        "name": "[3] Query Hourly Trend (HOURLY DB)",
        "func": "// [3] Query hourly trend from energy_hour\nconst TOKEN = 'apiv3_ds_pESsacfI0_vXWdSHp49SZaXPbODKnd8gaSQopgUOV-ijAiLEeqLy3IiyXhp0bQtGmN1pHOHS83CJfKWqP7w', HOST = 'http://influxdb:8181';\nconst sql = `SELECT DATE_BIN(INTERVAL '1 hour', time, TIMESTAMP '1970-01-01') AS hour_bucket,\n  machine_id, SUM(sum_energy_kwh) AS energy_kwh\nFROM energy_hour\nWHERE time >= DATE_TRUNC('day', NOW()) AND time < DATE_TRUNC('day', NOW()) + INTERVAL '1 day'\nGROUP BY hour_bucket, machine_id ORDER BY hour_bucket ASC, machine_id ASC`;\nmsg.url     = HOST + '/api/v3/query';\nmsg.method  = 'POST';\nmsg.headers = { 'Authorization': 'Bearer ' + TOKEN, 'Content-Type': 'application/json' };\nmsg.payload = JSON.stringify({ query: sql, database: 'energy_hour', format: 'json' });\nreturn msg;",
        "outputs": 1,
        "x": 460,
        "y": 200,
        "wires": [
            [
                "dash-http-hourly"
            ]
        ]
    },
    {
        "id": "dash-http-hourly",
        "type": "http request",
        "z": "tab-dashboard",
        "name": "[3] POST /api/v3/query HOURLY",
        "method": "use",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "x": 720,
        "y": 200,
        "wires": [
            [
                "dash-fn-parse-hourly"
            ]
        ]
    },
    {
        "id": "dash-fn-parse-hourly",
        "type": "function",
        "z": "tab-dashboard",
        "name": "[3] Format Line Chart",
        "func": "try {\n  const rows = Array.isArray(msg.payload) ? msg.payload : [];\n  const machineMap = {}, hourSet = new Set();\n  rows.forEach(r => {\n    const h = new Date(r.hour_bucket).getUTCHours();\n    const label = String(h).padStart(2,'0') + ':00';\n    hourSet.add(label);\n    if (!machineMap[r.machine_id]) machineMap[r.machine_id] = {};\n    machineMap[r.machine_id][label] = Math.round(parseFloat(r.energy_kwh)*1000)/1000;\n  });\n  const labels = Array.from(hourSet).sort();\n  const datasets = Object.entries(machineMap).map(([m,d]) => ({ label:m, data:labels.map(h=>d[h]||0) }));\n  const results = flow.get('dash_results') || {};\n  results.line_chart = { title: 'Konsumsi Energi Per Jam', labels, datasets };\n  flow.set('dash_results', results);\n} catch(e) { node.warn('[dash] hourly: ' + e.message); }\nreturn msg;",
        "outputs": 1,
        "x": 960,
        "y": 200,
        "wires": [
            [
                "dash-fn-pie"
            ]
        ]
    },
    {
        "id": "dash-fn-pie",
        "type": "function",
        "z": "tab-dashboard",
        "name": "[4] Query Pie Chart (MINUTES DB)",
        "func": "// [4] Query pie chart: total kWh per machine from energy_minutes\nconst TOKEN = 'apiv3_ds_pESsacfI0_vXWdSHp49SZaXPbODKnd8gaSQopgUOV-ijAiLEeqLy3IiyXhp0bQtGmN1pHOHS83CJfKWqP7w', HOST = 'http://influxdb:8181';\nconst sql = `SELECT machine_id, SUM(sum_energy_kwh) AS total_kwh\nFROM energy_minute\nWHERE time >= DATE_TRUNC('day', NOW()) AND time < NOW()\nGROUP BY machine_id ORDER BY total_kwh DESC`;\nmsg.url     = HOST + '/api/v3/query';\nmsg.method  = 'POST';\nmsg.headers = { 'Authorization': 'Bearer ' + TOKEN, 'Content-Type': 'application/json' };\nmsg.payload = JSON.stringify({ query: sql, database: 'energy_minutes', format: 'json' });\nreturn msg;",
        "outputs": 1,
        "x": 460,
        "y": 300,
        "wires": [
            [
                "dash-http-pie"
            ]
        ]
    },
    {
        "id": "dash-http-pie",
        "type": "http request",
        "z": "tab-dashboard",
        "name": "[4] POST /api/v3/query MINUTES",
        "method": "use",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "x": 720,
        "y": 300,
        "wires": [
            [
                "dash-fn-parse-pie"
            ]
        ]
    },
    {
        "id": "dash-fn-parse-pie",
        "type": "function",
        "z": "tab-dashboard",
        "name": "[4] Format Pie Chart",
        "func": "try {\n  const rows = Array.isArray(msg.payload) ? msg.payload : [];\n  const results = flow.get('dash_results') || {};\n  results.pie_chart = {\n    title: 'Distribusi Konsumsi Per Mesin — Hari Ini',\n    labels: rows.map(r=>r.machine_id),\n    values: rows.map(r=>Math.round(parseFloat(r.total_kwh)*1000)/1000),\n    unit: 'kWh'\n  };\n  flow.set('dash_results', results);\n} catch(e) { node.warn('[dash] pie: ' + e.message); }\nreturn msg;",
        "outputs": 1,
        "x": 960,
        "y": 300,
        "wires": [
            [
                "dash-fn-merge"
            ]
        ]
    },
    {
        "id": "dash-fn-merge",
        "type": "function",
        "z": "tab-dashboard",
        "name": "[5] Merge All -> JSON Response",
        "func": "// [5] Merge results and return JSON API response\nconst results = flow.get('dash_results') || {};\nmsg.payload = {\n  generated_at: new Date().toISOString(),\n  realtime:   results.realtime   || { total_power_kw: 0, machines: [] },\n  line_chart: results.line_chart || { title: '', labels: [], datasets: [] },\n  pie_chart:  results.pie_chart  || { title: '', labels: [], values: [], unit: 'kWh' }\n};\nmsg.req = flow.get('dash_req');\nmsg.res = flow.get('dash_res');\nmsg.statusCode = 200;\nmsg.headers = { 'Content-Type': 'application/json', 'Access-Control-Allow-Origin': '*' };\nnode.status({ fill: 'green', shape: 'dot', text: 'Served @ ' + new Date().toISOString().substring(11,19) });\nreturn msg;",
        "outputs": 1,
        "x": 460,
        "y": 420,
        "wires": [
            [
                "dash-http-response"
            ]
        ]
    },
    {
        "id": "dash-http-response",
        "type": "http response",
        "z": "tab-dashboard",
        "name": "[5] JSON API Response",
        "statusCode": "",
        "headers": {},
        "x": 720,
        "y": 420,
        "wires": []
    },
    {
        "id": "dash-catch",
        "type": "catch",
        "z": "tab-dashboard",
        "name": "Error Handler",
        "scope": null,
        "uncaught": false,
        "x": 200,
        "y": 520,
        "wires": [
            [
                "dash-fn-err"
            ]
        ]
    },
    {
        "id": "dash-fn-err",
        "type": "function",
        "z": "tab-dashboard",
        "name": "Error -> 500 Response",
        "func": "node.warn('[dash] Error: ' + msg.error.message);\nmsg.statusCode = 500;\nmsg.payload = JSON.stringify({ error: msg.error.message });\nmsg.headers = { 'Content-Type': 'application/json' };\nreturn msg;",
        "outputs": 1,
        "x": 460,
        "y": 520,
        "wires": [
            [
                "dash-http-response"
            ]
        ]
    }
]